generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String        @id @default(cuid())
  name              String?
  email             String        @unique
  emailVerified     DateTime?     @map("email_verified")
  image             String?
  hashedPassword    String?       @map("hashed_password")
  role              Role          @default(MEMBER)
  status            UserStatus    @default(PENDING)
  preferredLocale   String        @default("th") @map("preferred_locale")
  bio               String?
  phone             String?
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  accounts          Account[]
  activityLogs      ActivityLog[]
  articlesAuthored  Article[]     @relation("ArticleAuthor")
  articlesPublished Article[]     @relation("ArticlePublisher")
  sessions          Session[]
  media             Media[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  metadata  Json?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}

model Category {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  articles    Article[]

  @@map("categories")
}

model Article {
  id            String        @id @default(cuid())
  slug          String        @unique
  title         String
  excerpt       String?
  content       Json
  featuredImage String?       @map("featured_image")
  status        ArticleStatus @default(DRAFT)
  publishedAt   DateTime?     @map("published_at")
  scheduledAt   DateTime?     @map("scheduled_at")
  viewCount     Int           @default(0) @map("view_count")
  authorId      String        @map("author_id")
  publisherId   String?       @map("publisher_id")
  categoryId    String?       @map("category_id")
  tags          String[]      @default([])
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  author        User          @relation("ArticleAuthor", fields: [authorId], references: [id])
  category      Category?     @relation(fields: [categoryId], references: [id])
  publisher     User?         @relation("ArticlePublisher", fields: [publisherId], references: [id])

  @@index([slug])
  @@index([publishedAt])
  @@index([status])
  @@index([tags])
  @@map("articles")
}

model AwardYear {
  id           String         @id @default(cuid())
  year         Int            @unique
  edition      Int?
  theme        String?
  ceremonyDate DateTime?      @map("ceremony_date")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  nominees     AwardNominee[]

  @@map("award_years")
}

model AwardCategory {
  id          String         @id @default(cuid())
  name        String
  description String?
  type        AwardType      @default(TELEVISION)
  order       Int            @default(0)
  nominees    AwardNominee[]

  @@map("award_categories")
}

model AwardNominee {
  id                  String        @id @default(cuid())
  yearId              String        @map("year_id")
  categoryId          String        @map("category_id")
  nomineeName         String
  workTitle           String?
  broadcastingChannel String?
  imageUrl            String?       @map("image_url")
  isWinner            Boolean       @default(false) @map("is_winner")
  videoUrl            String?       @map("video_url")
  gallery             Json?         @map("gallery")
  category            AwardCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  year                AwardYear     @relation(fields: [yearId], references: [id], onDelete: Cascade)

  @@index([yearId])
  @@index([categoryId])
  @@map("award_nominees")
}

model Event {
  id                   String      @id @default(cuid())
  slug                 String      @unique
  title                String
  excerpt              String?
  description          String?
  eventType            EventType   @default(OTHER) @map("event_type")
  status               EventStatus @default(UPCOMING)
  startDate            DateTime    @map("start_date")
  endDate              DateTime?   @map("end_date")
  location             String?
  imageUrl             String?     @map("image_url")
  tags                 String[]
  capacity             String?
  ticketPrice          String?     @map("ticket_price")
  registrationDeadline DateTime?   @map("registration_deadline")
  registerUrl          String?     @map("register_url")
  mapEmbedUrl          String?     @map("map_embed_url")
  mapDirectionUrl      String?     @map("map_direction_url")
  agenda               Json?
  speakers             Json?
  resources            Json?
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  @@index([slug])
  @@index([status])
  @@map("events")
}

model Media {
  id           String   @id @default(cuid())
  url          String   @unique
  path         String   @unique
  name         String
  originalName String   @map("original_name")
  type         String   // image/png, image/jpeg, etc.
  size         Int
  width        Int?
  height       Int?
  altText      String?  @map("alt_text")
  folder       String   @default("general")
  userId       String   @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([folder])
  @@index([type])
  @@map("media")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
  AUTHOR
  TRANSLATOR
  JURY
  MEMBER
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DELETED
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  SCHEDULED
}

enum AwardType {
  TELEVISION
  RADIO
  DIGITAL
  SPECIAL
}

enum EventType {
  AWARD_CEREMONY
  SEMINAR
  WORKSHOP
  PRESS_CONFERENCE
  MEETING
  OTHER
}

enum EventStatus {
  UPCOMING
  OPEN_FOR_REGISTRATION
  ONGOING
  COMPLETED
  CANCELLED
}
